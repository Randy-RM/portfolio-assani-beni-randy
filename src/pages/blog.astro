---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogApp from "../react-pages/BlogApp";

const allPosts = await getCollection("posts");

const posts = allPosts.map((entry) => ({
  ...entry.data,
  slug: entry.slug,
  body: entry.body,
}));
---

<BaseLayout
  title="Blog | Randy Assani RM"
  description="Read articles about software engineering, frontend craft, and delivery workflows."
>
  <BlogApp client:load posts={posts} />
</BaseLayout>
