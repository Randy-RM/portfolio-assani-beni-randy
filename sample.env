## -- Variables d'environnement pour Astro
## -- En Astro, les variables publiques (accessibles côté client) doivent avoir le préfixe PUBLIC_

## -- EmailJS - envoi d'emails depuis le formulaire de contact
## -- https://www.emailjs.com/
PUBLIC_EMAILJS_SERVICE_ID=your_service_id
PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

## -- URL du site (utilisée pour les meta tags SEO et le sitemap)
HOME_LOCATION=http://localhost:4321

